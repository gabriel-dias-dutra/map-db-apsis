# Credenciais da ferramenta SQL (AWS Lambda) consumida por scripts locais como
# `npm run laudo-details:introspect` em repos/sql/. Copie este arquivo para
# `.env.tool` na raiz do wrapper e preencha os valores reais (não versione).

URL=https://<lambda-function-url-or-api-gateway>/
API_KEY=<api-key-da-lambda>
